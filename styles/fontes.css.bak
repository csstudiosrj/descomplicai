/* ============================================================
   CLASSES DE ESTILO — Aplicadas pelo VisualEngine dinamicamente
   Cada classe define --font-display e --font-body para o estilo
   ============================================================ */

/* --- CLASSICO --- */
.fonte-estilo-classico {
  --font-display: 'Cormorant Garamond', 'Georgia', serif;
  --font-body: 'Playfair Display', 'Georgia', serif;
}

/* --- RUSTICO --- */
.fonte-estilo-rustico {
  --font-display: 'Amatic SC', 'Georgia', serif;
  --font-body: 'Lora', 'Georgia', serif;
}

/* --- BOHO --- */
.fonte-estilo-boho {
  --font-display: 'Cormorant Garamond', 'Georgia', serif;
  --font-body: 'Josefin Sans', 'Helvetica Neue', sans-serif;
}

/* --- MODERNO --- */
.fonte-estilo-moderno {
  --font-display: 'Montserrat', 'Helvetica Neue', sans-serif;
  --font-body: 'Open Sans', 'Helvetica Neue', sans-serif;
}

/* --- MINIMALISTA --- */
.fonte-estilo-minimalista {
  --font-display: 'Cormorant Garamond', 'Georgia', serif;
  --font-body: 'Inter', 'Helvetica Neue', sans-serif;
}

/* --- INDUSTRIAL --- */
.fonte-estilo-industrial {
  --font-display: 'Oswald', 'Helvetica Neue', sans-serif;
  --font-body: 'Roboto', 'Helvetica Neue', sans-serif;
}

/* --- TROPICAL --- */
.fonte-estilo-tropical {
  --font-display: 'Pacifico', 'Georgia', serif;
  --font-body: 'Nunito', 'Helvetica Neue', sans-serif;
}

/* --- ROMANTICO --- */
.fonte-estilo-romantico {
  --font-display: 'Great Vibes', 'Georgia', serif;
  --font-body: 'Lora', 'Georgia', serif;
}

/* --- GOTICO --- */
.fonte-estilo-gotico {
  --font-display: 'Cinzel Decorative', 'Georgia', serif;
  --font-body: 'Crimson Text', 'Georgia', serif;
}

/* --- VINTAGE --- */
.fonte-estilo-vintage {
  --font-display: 'Cormorant Garamond', 'Georgia', serif;
  --font-body: 'EB Garamond', 'Georgia', serif;
}


/* ============================================================
   CLASSES DE PAR — Para quando o casal escolhe uma combinacao especifica
   Usadas pelo VisualEngine quando parId e definido
   ============================================================ */

/* --- CLASSICO --- */
.fonte-par-classico-1 { --font-display: 'Cormorant Garamond', 'Georgia', serif; --font-body: 'Playfair Display', 'Georgia', serif; }
.fonte-par-classico-2 { --font-display: 'EB Garamond', 'Georgia', serif; --font-body: 'Crimson Text', 'Georgia', serif; }
.fonte-par-classico-3 { --font-display: 'Cormorant Garamond', 'Georgia', serif; --font-body: 'Libre Baskerville', 'Georgia', serif; }
.fonte-par-classico-4 { --font-display: 'Playfair Display', 'Georgia', serif; --font-body: 'Source Serif 4', 'Georgia', serif; }

/* --- RUSTICO --- */
.fonte-par-rustico-1 { --font-display: 'Amatic SC', 'Georgia', serif; --font-body: 'Lora', 'Georgia', serif; }
.fonte-par-rustico-2 { --font-display: 'Dancing Script', 'Georgia', serif; --font-body: 'Lora', 'Georgia', serif; }
.fonte-par-rustico-3 { --font-display: 'Parisienne', 'Georgia', serif; --font-body: 'Lora', 'Georgia', serif; }

/* --- BOHO --- */
.fonte-par-boho-1 { --font-display: 'Cormorant Garamond', 'Georgia', serif; --font-body: 'Josefin Sans', 'Helvetica Neue', sans-serif; }
.fonte-par-boho-2 { --font-display: 'Dancing Script', 'Georgia', serif; --font-body: 'Josefin Sans', 'Helvetica Neue', sans-serif; }
.fonte-par-boho-3 { --font-display: 'Parisienne', 'Georgia', serif; --font-body: 'Lora', 'Georgia', serif; }

/* --- MODERNO --- */
.fonte-par-moderno-1 { --font-display: 'Montserrat', 'Helvetica Neue', sans-serif; --font-body: 'Open Sans', 'Helvetica Neue', sans-serif; }
.fonte-par-moderno-2 { --font-display: 'Oswald', 'Helvetica Neue', sans-serif; --font-body: 'Roboto', 'Helvetica Neue', sans-serif; }
.fonte-par-moderno-3 { --font-display: 'Montserrat', 'Helvetica Neue', sans-serif; --font-body: 'Inter', 'Helvetica Neue', sans-serif; }

/* --- MINIMALISTA --- */
.fonte-par-minimalista-1 { --font-display: 'Cormorant Garamond', 'Georgia', serif; --font-body: 'Inter', 'Helvetica Neue', sans-serif; }
.fonte-par-minimalista-2 { --font-display: 'Montserrat', 'Helvetica Neue', sans-serif; --font-body: 'Inter', 'Helvetica Neue', sans-serif; }
.fonte-par-minimalista-3 { --font-display: 'Oswald', 'Helvetica Neue', sans-serif; --font-body: 'Open Sans', 'Helvetica Neue', sans-serif; }

/* --- INDUSTRIAL --- */
.fonte-par-industrial-1 { --font-display: 'Oswald', 'Helvetica Neue', sans-serif; --font-body: 'Roboto', 'Helvetica Neue', sans-serif; }
.fonte-par-industrial-2 { --font-display: 'Montserrat', 'Helvetica Neue', sans-serif; --font-body: 'Roboto', 'Helvetica Neue', sans-serif; }
.fonte-par-industrial-3 { --font-display: 'Oswald', 'Helvetica Neue', sans-serif; --font-body: 'Open Sans', 'Helvetica Neue', sans-serif; }

/* --- TROPICAL --- */
.fonte-par-tropical-1 { --font-display: 'Pacifico', 'Georgia', serif; --font-body: 'Nunito', 'Helvetica Neue', sans-serif; }
.fonte-par-tropical-2 { --font-display: 'Dancing Script', 'Georgia', serif; --font-body: 'Nunito', 'Helvetica Neue', sans-serif; }
.fonte-par-tropical-3 { --font-display: 'Great Vibes', 'Georgia', serif; --font-body: 'Nunito', 'Helvetica Neue', sans-serif; }

/* --- ROMANTICO --- */
.fonte-par-romantico-1 { --font-display: 'Great Vibes', 'Georgia', serif; --font-body: 'Lora', 'Georgia', serif; }
.fonte-par-romantico-2 { --font-display: 'Parisienne', 'Georgia', serif; --font-body: 'Lora', 'Georgia', serif; }
.fonte-par-romantico-3 { --font-display: 'Dancing Script', 'Georgia', serif; --font-body: 'Lora', 'Georgia', serif; }
.fonte-par-romantico-4 { --font-display: 'Great Vibes', 'Georgia', serif; --font-body: 'Libre Baskerville', 'Georgia', serif; }

/* --- GOTICO --- */
.fonte-par-gotico-1 { --font-display: 'Cinzel Decorative', 'Georgia', serif; --font-body: 'Crimson Text', 'Georgia', serif; }
.fonte-par-gotico-2 { --font-display: 'Cinzel Decorative', 'Georgia', serif; --font-body: 'EB Garamond', 'Georgia', serif; }
.fonte-par-gotico-3 { --font-display: 'Oswald', 'Helvetica Neue', sans-serif; --font-body: 'Crimson Text', 'Georgia', serif; }

/* --- VINTAGE --- */
.fonte-par-vintage-1 { --font-display: 'Cormorant Garamond', 'Georgia', serif; --font-body: 'EB Garamond', 'Georgia', serif; }

/* ============================================================
   FONTES CUSTOMIZADAS — Descomplicaí Memorial
   24 famílias, 46 arquivos .woff2
   font-display: swap em todos (evita FOIT)
   ============================================================ */

/* ────────────────────────────────────────────────────────────
   1. AMATIC SC (Display — Rustico)
   ──────────────────────────────────────────────────────────── */
@font-face {
  font-family: 'Amatic SC';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('/descomplicai/fonts/amatic-sc-v28-latin-regular.woff2') format('woff2');
}
@font-face {
  font-family: 'Amatic SC';
  font-style: normal;
  font-weight: 700;
  font-display: swap;
  src: url('/descomplicai/fonts/amatic-sc-v28-latin-700.woff2') format('woff2');
}

